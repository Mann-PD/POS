rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // AUTHENTICATION CHECK - DENY ALL IF NOT AUTHENTICATED
    // ============================================
    
    // Global check: deny all access if not authenticated
    function requireAuth() {
      return request.auth != null;
    }
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Get user document from Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Normalize role from Firestore (rules see raw values, not Flutter normalization)
    function normalizedRole(role) {
      return role == 'SuperAdmin' || role == 'Super Admin' || role == 'superadmin' || role == 'super_admin';
    }
    function normalizedRoleAdmin(role) {
      return role == 'Admin' || role == 'admin';
    }
    function normalizedRoleEmployee(role) {
      return role == 'Employee' || role == 'employee';
    }
    function normalizedRoleViewer(role) {
      return role == 'Viewer' || role == 'viewer';
    }

    // Get user role (canonical: SuperAdmin, Admin, Employee, Viewer)
    function getUserRole() {
      return requireAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? getUserData().role 
        : null;
    }
    
    // Get user shopId
    function getUserShopId() {
      return requireAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? getUserData().shopId 
        : null;
    }
    
    // Canonical enum validation (reject unknown values)
    function isValidRole(role) {
      return role == 'SuperAdmin' || role == 'Admin' || role == 'Employee' || role == 'Viewer';
    }
    function isValidStatus(status) {
      return status == 'Active' || status == 'Inactive' || status == 'Suspended';
    }
    function isValidOrderStatus(orderStatus) {
      return orderStatus == 'pending' || orderStatus == 'locked' || orderStatus == 'cancelled';
    }
    function isValidPaymentStatus(paymentStatus) {
      return paymentStatus == 'Success' || paymentStatus == 'Pending' || paymentStatus == 'Failed';
    }
    
    // Check if user is Super Admin
    function isSuperAdmin() {
      return normalizedRole(getUserRole());
    }
    
    // Check if user is Admin
    function isAdmin() {
      return normalizedRoleAdmin(getUserRole());
    }
    
    // Check if user is Employee
    function isEmployee() {
      return normalizedRoleEmployee(getUserRole());
    }
    
    // Check if user is Viewer
    function isViewer() {
      return normalizedRoleViewer(getUserRole());
    }
    
    // Check if user is active (string "Active" or legacy bool/int from older seeds)
    function isUserActive() {
      return requireAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && (
          getUserData().status == 'Active' ||
          getUserData().status == true ||
          getUserData().status == 1
        );
    }
    
    // Check if resource shopId matches user shopId
    function isSameShop(resourceShopId) {
      return getUserShopId() == resourceShopId;
    }
    
    // Check if user owns the resource (userId matches)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Validate shopId is present and matches user's shop (except Super Admin)
    function validateShopId(resourceShopId) {
      return isSuperAdmin() || (resourceShopId != null && isSameShop(resourceShopId));
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && isSameShop(resource.data.shopId)) || // Admin: read users in same shop
        (isEmployee() && isOwner(userId)) // Employee: read own user document only
      );
      // Viewer: no access (implicitly denied)
      
      // Create rules
      allow create: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: create all
        (isAdmin() && validateShopId(request.resource.data.shopId) && 
         request.resource.data.role == 'Employee') // Admin: create employees in same shop
      ) &&
      // Validate required fields
      request.resource.data.keys().hasAll(['userId', 'name', 'email', 'phone', 'role', 'shopId', 'status', 'createdAt']) &&
      request.resource.data.userId == userId &&
      request.resource.data.role is string &&
      request.resource.data.shopId is string &&
      request.resource.data.status is string &&
      request.resource.data.createdAt is timestamp &&
      // Canonical enum validation (reject unknown values)
      isValidRole(request.resource.data.role) &&
      isValidStatus(request.resource.data.status);
      
      // Update rules
      allow update: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: update all
        (isAdmin() && isSameShop(resource.data.shopId) && 
         resource.data.role == 'Employee' && 
         validateShopId(request.resource.data.shopId)) // Admin: update employees in same shop
      ) &&
      // Immutable fields: role and userId must not change
      request.resource.data.role == resource.data.role &&
      request.resource.data.userId == resource.data.userId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      // Prevent shopId change for non-Super Admin
      (isSuperAdmin() || request.resource.data.shopId == resource.data.shopId) &&
      // Canonical enum validation (reject unknown values)
      isValidRole(request.resource.data.role) &&
      isValidStatus(request.resource.data.status);
      
      // Delete rules — DENIED FOR ALL (no role, including SuperAdmin, may delete a user)
      allow delete: if false;
    }
    
    // ============================================
    // SHOPS COLLECTION
    // ============================================
    
    match /shops/{shopId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && isSameShop(shopId)) // Admin: read own shop
      );
      // All others: denied (implicitly)
      
      // Create rules
      allow create: if requireAuth() && isUserActive() && isSuperAdmin() &&
      request.resource.data.keys().hasAll(['shopId', 'name', 'status', 'createdAt']) &&
      request.resource.data.shopId == shopId;
      
      // Update rules
      allow update: if requireAuth() && isUserActive() && isSuperAdmin();
      
      // Delete rules
      allow delete: if requireAuth() && isUserActive() && isSuperAdmin();
    }
    
    // ============================================
    // PRODUCTS COLLECTION
    // ============================================
    
    match /products/{productId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && isSameShop(resource.data.shopId)) || // Admin: read own shop
        (isEmployee() && isSameShop(resource.data.shopId)) || // Employee: read own shop
        (isViewer() && isSameShop(resource.data.shopId)) // Viewer: read only
      );
      
      // Create rules
      allow create: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: create all
        (isAdmin() && validateShopId(request.resource.data.shopId)) // Admin: create in own shop
      ) &&
      // Validate required fields
      request.resource.data.keys().hasAll(['productId', 'shopId', 'name', 'price', 'measurementType', 'stock', 'status', 'createdAt']) &&
      request.resource.data.productId == productId &&
      request.resource.data.shopId is string &&
      request.resource.data.price is number &&
      request.resource.data.price > 0 &&
      request.resource.data.stock is number &&
      request.resource.data.stock >= 0 &&
      request.resource.data.createdAt is timestamp;
      
      // Update rules - clients cannot modify stock (only Cloud Functions / Admin SDK can)
      allow update: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: update all
        (isAdmin() && isSameShop(resource.data.shopId) && validateShopId(request.resource.data.shopId)) // Admin: update in own shop
      ) &&
      // Prevent shopId and productId changes
      request.resource.data.shopId == resource.data.shopId &&
      request.resource.data.productId == resource.data.productId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      // Block direct writes to stock: stock may only be changed by Cloud Functions (Admin SDK bypasses rules)
      request.resource.data.stock == resource.data.stock &&
      // Validate price > 0
      request.resource.data.price is number &&
      request.resource.data.price > 0 &&
      // Validate stock >= 0
      request.resource.data.stock is number &&
      request.resource.data.stock >= 0 &&
      // measurementType is permanently immutable — no role (including SuperAdmin) may change it
      request.resource.data.measurementType == resource.data.measurementType &&
      // Deletion (status -> 'Deleted') must go through the deleteProduct Cloud
      // Function (Admin SDK bypasses rules) so it is always audit-logged and
      // restricted to Super Admin — never settable via a direct client update.
      request.resource.data.status != 'Deleted';

      // Delete rules - DENIED FOR ALL. Deletion is a soft delete (status ->
      // 'Deleted') performed only by the deleteProduct Cloud Function
      // (Super Admin only), never a hard document delete — see
      // firebase/functions/src/products/deleteProduct.ts for why.
      allow delete: if false;
    }
    
    // ============================================
    // CATEGORIES COLLECTION
    // ============================================
    
    match /categories/{categoryId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && isSameShop(resource.data.shopId)) || // Admin: read own shop
        (isEmployee() && isSameShop(resource.data.shopId)) || // Employee: read own shop
        (isViewer() && isSameShop(resource.data.shopId)) // Viewer: read only
      );
      
      // Create rules
      allow create: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: create all
        (isAdmin() && validateShopId(request.resource.data.shopId)) // Admin: create in own shop
      ) &&
      request.resource.data.keys().hasAll(['categoryId', 'shopId', 'name', 'status', 'createdAt']) &&
      request.resource.data.categoryId == categoryId &&
      request.resource.data.shopId is string;
      
      // Update rules
      allow update: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: update all
        (isAdmin() && isSameShop(resource.data.shopId) && validateShopId(request.resource.data.shopId)) // Admin: update in own shop
      ) &&
      request.resource.data.shopId == resource.data.shopId &&
      request.resource.data.categoryId == resource.data.categoryId;

      // Delete rules — Admin has full Write (incl. delete) on their own
      // shop's categories per TECHNICAL REQUIREMENTS IN DETAIL.md Module 4
      // ("Admin: Write=All"). Previously restricted to Super Admin only,
      // which was stricter than the spec.
      allow delete: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: delete all
        (isAdmin() && isSameShop(resource.data.shopId)) // Admin: delete own shop
      );
    }

    // ============================================
    // CUSTOMERS COLLECTION
    // ============================================
    
    match /customers/{customerId} {
      // Read rules
      // Employees may read customers for their own shop (for POS workflow),
      // but cannot write.
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && isSameShop(resource.data.shopId)) || // Admin: read own shop customers
        (isEmployee() && isSameShop(resource.data.shopId)) // Employee: read own shop customers
      );
      // Viewer: no read access (implicitly denied)
      
      // Create rules
      allow create: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: create all
        (isAdmin() && validateShopId(request.resource.data.shopId)) || // Admin: create in own shop
        (isEmployee() && validateShopId(request.resource.data.shopId)) // Employee: create only (during billing)
      ) &&
      // Validate required fields
      request.resource.data.keys().hasAll(['customerId', 'shopId', 'name', 'mobile', 'createdAt']) &&
      request.resource.data.customerId == customerId &&
      request.resource.data.shopId is string &&
      request.resource.data.name is string &&
      request.resource.data.name.size() >= 2 &&
      request.resource.data.mobile is string &&
      request.resource.data.mobile.matches('^[0-9]{10}$') &&
      request.resource.data.createdAt is timestamp;
      
      // Update rules
      allow update: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: update all
        (isAdmin() && isSameShop(resource.data.shopId) && validateShopId(request.resource.data.shopId)) // Admin: update in own shop
      ) &&
      // Prevent shopId and customerId changes
      request.resource.data.shopId == resource.data.shopId &&
      request.resource.data.customerId == resource.data.customerId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      request.resource.data.name is string &&
      request.resource.data.name.size() >= 2 &&
      request.resource.data.mobile is string &&
      request.resource.data.mobile.matches('^[0-9]{10}$');
      // Employee: no update access (implicitly denied)
      
      // Delete rules - DENIED FOR ALL (customer deletion must be denied)
      allow delete: if false;
    }
    
    // ============================================
    // ORDERS COLLECTION
    // ============================================
    
    match /orders/{orderId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read only
        (isAdmin() && isSameShop(resource.data.shopId)) || // Admin: read only (own shop)
        (isEmployee() && isSameShop(resource.data.shopId) && isOwner(resource.data.employeeId)) || // Employee: read own orders only
        (isViewer() && isSameShop(resource.data.shopId)) // Viewer: read only
      );
      
      // Create rules - Only Employees can create orders
      allow create: if requireAuth() && isUserActive() && 
      isEmployee() && 
      validateShopId(request.resource.data.shopId) &&
      // Validate required fields
      request.resource.data.keys().hasAll(['orderId', 'shopId', 'customerId', 'employeeId', 'totalAmount', 'paymentMethod', 'paymentStatus', 'orderStatus', 'createdAt']) &&
      request.resource.data.orderId == orderId &&
      request.resource.data.employeeId == request.auth.uid &&
      request.resource.data.shopId is string &&
      request.resource.data.customerId is string &&
      request.resource.data.totalAmount is number &&
      request.resource.data.totalAmount > 0 &&
      request.resource.data.paymentStatus == 'Success' &&
      request.resource.data.createdAt is timestamp &&
      // Canonical enum validation (reject unknown values)
      isValidOrderStatus(request.resource.data.orderStatus) &&
      isValidPaymentStatus(request.resource.data.paymentStatus);
      
      // Update rules - prevent update if orderStatus == locked; only assigned employee can update pending orders
      allow update: if requireAuth() && isUserActive() &&
      resource.data.orderStatus != 'locked' &&
      isEmployee() &&
      isSameShop(resource.data.shopId) &&
      resource.data.employeeId == request.auth.uid &&
      validateShopId(request.resource.data.shopId) &&
      request.resource.data.orderId == resource.data.orderId &&
      request.resource.data.employeeId == resource.data.employeeId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      request.resource.data.shopId == resource.data.shopId &&
      request.resource.data.orderStatus == resource.data.orderStatus &&
      isValidOrderStatus(request.resource.data.orderStatus) &&
      isValidPaymentStatus(request.resource.data.paymentStatus);
      
      // Delete rules - prevent delete entirely
      allow delete: if false;
    }
    
    // ============================================
    // ORDER ITEMS COLLECTION
    // ============================================
    
    match /order_items/{orderItemId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read only
        (isAdmin() && exists(/databases/$(database)/documents/orders/$(resource.data.orderId)) && 
         isSameShop(get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.shopId)) || // Admin: read only (own shop)
        (isEmployee() && exists(/databases/$(database)/documents/orders/$(resource.data.orderId)) && 
         isOwner(get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.employeeId)) || // Employee: read own orders only
        (isViewer() && exists(/databases/$(database)/documents/orders/$(resource.data.orderId)) && 
         isSameShop(get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.shopId)) // Viewer: read only
      );
      
      // Create rules - Only Employees can create order items
      allow create: if requireAuth() && isUserActive() && 
      isEmployee() &&
      exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId)) &&
      isOwner(get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.employeeId) &&
      // Validate required fields
      request.resource.data.keys().hasAll(['orderItemId', 'orderId', 'shopId', 'productId', 'quantityOrWeight', 'priceSnapshot', 'totalPrice']) &&
      request.resource.data.orderItemId == orderItemId &&
      request.resource.data.orderId is string &&
      request.resource.data.shopId is string &&
      request.resource.data.shopId == get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.shopId &&
      request.resource.data.productId is string &&
      request.resource.data.quantityOrWeight is number &&
      request.resource.data.quantityOrWeight > 0 &&
      request.resource.data.priceSnapshot is number &&
      request.resource.data.priceSnapshot > 0 &&
      request.resource.data.totalPrice is number &&
      request.resource.data.totalPrice > 0;
      
      // Update rules - NO UPDATES ALLOWED (immutable after creation)
      allow update: if false;
      
      // Delete rules - NO DELETES ALLOWED
      allow delete: if false;
    }
    
    // ============================================
    // EXPENSES COLLECTION
    // ============================================
    // Block all direct writes. Only Cloud Functions (Admin SDK) may write.
    // request.auth.token.admin is not checkable for client writes (all client writes denied).
    // Employees: no access (read or write).

    match /expenses/{expenseId} {
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() ||
        (isAdmin() && isSameShop(resource.data.shopId)) ||
        (isViewer() && isSameShop(resource.data.shopId))
      );
      // Employees: no read (no allow rule for isEmployee())

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    // ============================================
    // INVENTORY LOGS COLLECTION
    // ============================================
    // Block all direct writes; only Cloud Functions (Admin SDK) may write.
    
    match /inventory_logs/{logId} {
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read only
        (isAdmin() && isSameShop(resource.data.shopId)) // Admin: read only (own shop)
      );

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // LOW STOCK ALERTS COLLECTION
    // ============================================
    // Created/resolved only by the onProductStockChange trigger (Admin SDK
    // bypasses rules). Read-only for Admin (own shop) / Super Admin (all) —
    // Requirement in Detail §27.3 / §34.2.

    match /low_stock_alerts/{alertId} {
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && isSameShop(resource.data.shopId)) // Admin: read only (own shop)
      );

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // AUDIT LOGS COLLECTION
    // ============================================
    // Append only (writes via Cloud Functions); no update; no delete.
    
    match /audit_logs/{logId} {
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read only
        (isAdmin() && isSameShop(resource.data.shopId)) // Admin: read only (own shop)
      );
      
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    // ============================================
    // SETTINGS COLLECTION
    // ============================================
    
    match /settings/{settingId} {
      // Read rules
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: read all
        (isAdmin() && resource.data.scope == 'shop' && resource.data.shopId != null && isSameShop(resource.data.shopId)) || // Admin: read own shop settings
        // Employee: narrow exception, payment-method toggles ONLY (own shop).
        // The Payment Selection Screen must respect Admin's "Enable/disable
        // payment methods" setting (Requirement in Detail §32.2), so Employee
        // needs read access to exactly these 3 keys — not the general
        // Settings module, which stays fully denied to Employee.
        (isEmployee() && resource.data.scope == 'shop' && resource.data.shopId != null &&
         isSameShop(resource.data.shopId) &&
         resource.data.key in ['payment_cash_enabled', 'payment_upi_enabled', 'payment_card_enabled'])
      );
      // Viewer: no access (implicitly denied)
      
      // Create rules
      allow create: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: create all
        (isAdmin() && request.resource.data.scope == 'shop' && validateShopId(request.resource.data.shopId)) // Admin: create own shop settings
      ) &&
      request.resource.data.keys().hasAll(['settingId', 'scope', 'key', 'value', 'updatedAt']) &&
      request.resource.data.settingId == settingId &&
      request.resource.data.scope is string &&
      // Shop-level settings must have shopId
      (request.resource.data.scope == 'system' || (request.resource.data.scope == 'shop' && request.resource.data.shopId is string));
      
      // Update rules
      allow update: if requireAuth() && isUserActive() && (
        isSuperAdmin() || // Super Admin: update all
        (isAdmin() && resource.data.scope == 'shop' && resource.data.shopId != null && isSameShop(resource.data.shopId) && 
         request.resource.data.scope == 'shop' && validateShopId(request.resource.data.shopId)) // Admin: update own shop settings
      ) &&
      request.resource.data.settingId == resource.data.settingId &&
      request.resource.data.scope == resource.data.scope;
      
      // Delete rules
      allow delete: if requireAuth() && isUserActive() && isSuperAdmin();
    }
    
    // ============================================
    // LOGIN ATTEMPTS COLLECTION
    // ============================================
    // Tracks per-user failed login counters for lockout enforcement.
    // All writes are performed exclusively by Cloud Functions (Admin SDK).
    // No client — regardless of role — may write to this collection.

    match /login_attempts/{userId} {
      // SuperAdmin and Admin may read lockout state (support visibility)
      allow read: if requireAuth() && isUserActive() && (
        isSuperAdmin() ||
        (isAdmin() && isSameShop(get(/databases/$(database)/documents/users/$(userId)).data.shopId))
      );

      // All client writes are permanently denied — Admin SDK bypasses rules
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // DEFAULT DENY RULE
    // ============================================
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
